# ============================================
# Lola's Party System — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# Google Maps Distance Matrix API key
# Used for calculating delivery distance and fees
MAPS_API_KEY=

# Gmail app password for transactional emails
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=

# Stripe secret key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=

# Google Sheets spreadsheet ID for the accounting ledger
# Found in the Sheets URL: docs.google.com/spreadsheets/d/<THIS_VALUE>/edit
SPREADSHEET_ID=

# Shared secret for Cloud Scheduler cron job authentication
CRON_SECRET=
